{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm pack:*)",
      "Bash(npm ls:*)",
      "Bash(node --check:*)",
      "Bash(node --version)",
      "Bash(npx playwright:*)",
      "Bash(bash -n:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git --version)",
      "Bash(git check-ignore:*)",
      "Bash(git ls-files:*)",
      "Skill(sq-git:commit)",
      "Skill(sq-git:open-pr)",
      "Skill(sq-git:sync-branch)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": [
      "Bash(./setup.sh:*)",
      "Bash(git push:*)"
    ]
  }
}
